TARGET_URL=
# Leave blank — slot cells are td[onclick^="selectDate"], no container selector needed
CALENDAR_SELECTOR=
# Filter to one exam category (e.g. 普通車ＡＭ, 普通車ＰＭ, 大型車ＡＭ). Empty = all categories.
SLOT_CATEGORY=普通車ＡＭ
# Alert only for slots before this date (YYYYMMDD). Empty = no threshold (all future dates qualify).
ALERT_BEFORE=20260620
# Slack incoming webhook URL for slot-available notifications. Leave blank to disable Slack alerts.
SLACK_WEBHOOK_URL=
# Path to Chrome/Chromium binary. Leave blank in CI (Playwright uses its own installed binary).
# macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_PATH=
